public class Solution {
    public boolean isPalindrome(ListNode head) {
        if (head==null || head.next==null){
            return true;
        }
        ListNode fast=head;
        ListNode slow=head;
        while (fast!=null && fast.next!=null){ //finding the mid position of the list
            fast=fast.next.next;
            slow=slow.next;
        }
        if (fast!=null){
            slow=slow.next;
        }
        
        slow=reverseList(slow); //second half of list is reversed
        fast=head;
        while (slow!=null){ //not a palindrome if the corresponding nodes in first half and reversed second half are not matching
            if (fast.val!=slow.val){
                return false;
            }
            fast=fast.next;
            slow=slow.next;
        }
        return true;
    }
    
    public ListNode reverseList(ListNode head){ //code for reversing a list
        if (head.next==null){
            return head;
        }
        ListNode prev=null;
        ListNode current=head;
        ListNode next=head.next;

        while (current.next!=null){
            current.next=prev;
            prev=current;
            current=next;
            next=current.next;
        }
        current.next=prev;
        return current;
    }
}
